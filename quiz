<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Prawo Medyczne – Interaktywny Test</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0d0f14;
    --surface: #13161e;
    --card: #1a1e2a;
    --border: #252a38;
    --accent: #c8a96e;
    --accent2: #4fc3a1;
    --accent3: #e05c5c;
    --text: #e8eaf0;
    --muted: #6b7294;
    --highlight: #2a3050;
    --correct: #1e3d32;
    --correct-border: #4fc3a1;
    --wrong: #3d1e1e;
    --wrong-border: #e05c5c;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* BG PATTERN */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      radial-gradient(ellipse 80% 50% at 20% 10%, rgba(200,169,110,0.07) 0%, transparent 60%),
      radial-gradient(ellipse 60% 40% at 80% 80%, rgba(79,195,161,0.05) 0%, transparent 60%);
    pointer-events: none;
    z-index: 0;
  }

  /* ─── INTRO SCREEN ─── */
  #intro {
    position: relative;
    z-index: 1;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 40px 20px;
    text-align: center;
  }
  .logo-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: rgba(200,169,110,0.12);
    border: 1px solid rgba(200,169,110,0.3);
    border-radius: 50px;
    padding: 8px 20px;
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 32px;
    animation: fadeDown 0.6s ease both;
  }
  h1.main-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.4rem, 6vw, 4.5rem);
    font-weight: 900;
    line-height: 1.1;
    margin-bottom: 16px;
    animation: fadeDown 0.7s 0.1s ease both;
  }
  h1.main-title span { color: var(--accent); }
  .subtitle {
    font-size: 1.05rem;
    color: var(--muted);
    max-width: 520px;
    line-height: 1.7;
    margin-bottom: 48px;
    animation: fadeDown 0.7s 0.2s ease both;
  }

  .stats-row {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: 48px;
    animation: fadeUp 0.7s 0.3s ease both;
  }
  .stat-chip {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 16px 28px;
    text-align: center;
  }
  .stat-chip .num {
    font-family: 'DM Mono', monospace;
    font-size: 1.8rem;
    font-weight: 500;
    color: var(--accent);
    display: block;
  }
  .stat-chip .lbl { font-size: 0.78rem; color: var(--muted); letter-spacing: 1px; text-transform: uppercase; }

  .mode-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    max-width: 540px;
    width: 100%;
    margin-bottom: 40px;
    animation: fadeUp 0.7s 0.4s ease both;
  }
  .mode-card {
    background: var(--card);
    border: 2px solid var(--border);
    border-radius: 20px;
    padding: 28px 24px;
    cursor: pointer;
    transition: all 0.25s;
    text-align: left;
    position: relative;
    overflow: hidden;
  }
  .mode-card::before {
    content: '';
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.25s;
  }
  .mode-card.study::before { background: radial-gradient(circle at 0% 0%, rgba(200,169,110,0.15), transparent 70%); }
  .mode-card.exam::before  { background: radial-gradient(circle at 100% 0%, rgba(79,195,161,0.12), transparent 70%); }
  .mode-card:hover { border-color: var(--accent); transform: translateY(-3px); }
  .mode-card:hover::before { opacity: 1; }
  .mode-card .mode-icon { font-size: 2rem; margin-bottom: 12px; display: block; }
  .mode-card .mode-name {
    font-family: 'Playfair Display', serif;
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 6px;
  }
  .mode-card .mode-desc { font-size: 0.82rem; color: var(--muted); line-height: 1.5; }

  .topic-select-area {
    max-width: 700px;
    width: 100%;
    animation: fadeUp 0.7s 0.5s ease both;
  }
  .topic-select-area h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    margin-bottom: 16px;
    color: var(--muted);
    text-align: left;
  }
  .topic-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 32px;
  }
  .topic-pill {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 50px;
    padding: 10px 20px;
    font-size: 0.82rem;
    cursor: pointer;
    transition: all 0.2s;
    color: var(--muted);
  }
  .topic-pill.active {
    background: rgba(200,169,110,0.15);
    border-color: var(--accent);
    color: var(--accent);
  }
  .btn-start {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--accent);
    color: #0d0f14;
    border: none;
    border-radius: 14px;
    padding: 16px 36px;
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    letter-spacing: 0.5px;
  }
  .btn-start:hover { background: #d9bc84; transform: translateY(-2px); box-shadow: 0 8px 30px rgba(200,169,110,0.3); }

  /* ─── QUIZ SCREEN ─── */
  #quiz { display: none; position: relative; z-index: 1; min-height: 100vh; padding: 0 0 60px; }

  .quiz-header {
    background: rgba(13,15,20,0.95);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    padding: 16px 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .quiz-header-left { display: flex; align-items: center; gap: 16px; }
  .btn-back {
    background: var(--card);
    border: 1px solid var(--border);
    color: var(--text);
    border-radius: 10px;
    padding: 8px 16px;
    font-size: 0.82rem;
    cursor: pointer;
    transition: all 0.2s;
    font-family: 'DM Sans', sans-serif;
  }
  .btn-back:hover { border-color: var(--accent); color: var(--accent); }
  .mode-badge {
    font-size: 0.72rem;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 5px 14px;
    border-radius: 50px;
    font-weight: 600;
  }
  .mode-badge.study { background: rgba(200,169,110,0.15); color: var(--accent); border: 1px solid rgba(200,169,110,0.3); }
  .mode-badge.exam  { background: rgba(79,195,161,0.12); color: var(--accent2); border: 1px solid rgba(79,195,161,0.25); }

  .progress-bar-wrap { flex: 1; max-width: 300px; }
  .progress-bar-track { background: var(--border); border-radius: 4px; height: 6px; overflow: hidden; }
  .progress-bar-fill { background: linear-gradient(90deg, var(--accent), var(--accent2)); height: 100%; border-radius: 4px; transition: width 0.4s ease; }
  .progress-label { font-size: 0.72rem; color: var(--muted); margin-top: 4px; font-family: 'DM Mono', monospace; }

  .score-display { font-family: 'DM Mono', monospace; font-size: 0.85rem; color: var(--muted); }
  .score-display span { color: var(--accent2); font-weight: 500; }

  /* Topic nav */
  .topic-nav {
    padding: 24px 32px 0;
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .topic-nav-btn {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 8px 18px;
    font-size: 0.78rem;
    cursor: pointer;
    transition: all 0.2s;
    color: var(--muted);
    font-family: 'DM Sans', sans-serif;
  }
  .topic-nav-btn.active { background: rgba(200,169,110,0.15); border-color: var(--accent); color: var(--accent); }
  .topic-nav-btn .dot {
    display: inline-block;
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--border);
    margin-right: 6px;
    vertical-align: middle;
  }
  .topic-nav-btn.done .dot { background: var(--accent2); }

  /* Question area */
  .question-area {
    max-width: 820px;
    margin: 32px auto;
    padding: 0 24px;
  }
  .question-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 20px;
  }
  .q-number {
    font-family: 'DM Mono', monospace;
    font-size: 0.75rem;
    color: var(--muted);
    background: var(--card);
    border: 1px solid var(--border);
    padding: 4px 12px;
    border-radius: 6px;
  }
  .diff-badge {
    font-size: 0.7rem;
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: 6px;
    font-weight: 600;
  }
  .diff-easy   { background: rgba(79,195,161,0.12); color: var(--accent2); }
  .diff-medium { background: rgba(200,169,110,0.12); color: var(--accent); }
  .diff-hard   { background: rgba(224,92,92,0.12);  color: var(--accent3); }

  .question-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 36px;
    margin-bottom: 20px;
    position: relative;
    overflow: hidden;
  }
  .question-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--accent), var(--accent2));
    opacity: 0;
    transition: opacity 0.3s;
  }
  .question-card.answered::before { opacity: 1; }

  .question-text {
    font-family: 'Playfair Display', serif;
    font-size: 1.15rem;
    line-height: 1.65;
    margin-bottom: 28px;
    color: var(--text);
  }

  .options-list { display: flex; flex-direction: column; gap: 12px; }
  .option-btn {
    background: rgba(255,255,255,0.03);
    border: 1.5px solid var(--border);
    border-radius: 14px;
    padding: 16px 20px;
    text-align: left;
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    align-items: flex-start;
    gap: 14px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.92rem;
    line-height: 1.5;
    color: var(--text);
    width: 100%;
  }
  .option-btn:not(:disabled):hover {
    background: rgba(200,169,110,0.08);
    border-color: rgba(200,169,110,0.4);
    transform: translateX(3px);
  }
  .option-btn .opt-letter {
    min-width: 28px;
    height: 28px;
    border-radius: 8px;
    background: var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'DM Mono', monospace;
    font-size: 0.75rem;
    font-weight: 500;
    flex-shrink: 0;
    margin-top: 1px;
    transition: all 0.2s;
  }
  .option-btn.correct {
    background: var(--correct);
    border-color: var(--correct-border);
  }
  .option-btn.correct .opt-letter { background: var(--correct-border); color: #0d0f14; }
  .option-btn.wrong {
    background: var(--wrong);
    border-color: var(--wrong-border);
  }
  .option-btn.wrong .opt-letter { background: var(--wrong-border); color: #fff; }
  .option-btn.reveal-correct {
    background: rgba(79,195,161,0.06);
    border-color: rgba(79,195,161,0.3);
  }
  .option-btn:disabled { cursor: default; }

  /* Explanation */
  .explanation-box {
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: 4px solid var(--accent);
    border-radius: 14px;
    padding: 22px 24px;
    margin-top: 20px;
    display: none;
    animation: slideIn 0.3s ease;
  }
  .explanation-box.show { display: block; }
  .explanation-box .ex-header {
    font-size: 0.72rem;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 600;
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .explanation-box .ex-text { font-size: 0.9rem; line-height: 1.7; color: var(--muted); }
  .explanation-box .ex-law {
    margin-top: 10px;
    font-size: 0.78rem;
    color: rgba(200,169,110,0.7);
    font-family: 'DM Mono', monospace;
  }

  /* Nav buttons */
  .question-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 24px;
  }
  .btn-nav {
    background: var(--card);
    border: 1px solid var(--border);
    color: var(--text);
    border-radius: 12px;
    padding: 12px 24px;
    font-size: 0.88rem;
    cursor: pointer;
    transition: all 0.2s;
    font-family: 'DM Sans', sans-serif;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .btn-nav:hover { border-color: var(--accent); color: var(--accent); }
  .btn-nav:disabled { opacity: 0.3; cursor: default; }
  .btn-nav.primary {
    background: var(--accent);
    color: #0d0f14;
    border-color: var(--accent);
    font-weight: 600;
  }
  .btn-nav.primary:hover { background: #d9bc84; }

  /* Question grid (exam overview) */
  .q-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 8px;
  }
  .q-dot {
    width: 34px; height: 34px;
    border-radius: 8px;
    background: var(--card);
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    cursor: pointer;
    transition: all 0.2s;
    color: var(--muted);
  }
  .q-dot:hover { border-color: var(--accent); color: var(--accent); }
  .q-dot.answered-correct { background: var(--correct); border-color: var(--correct-border); color: var(--accent2); }
  .q-dot.answered-wrong   { background: var(--wrong); border-color: var(--wrong-border); color: var(--accent3); }
  .q-dot.current          { border-color: var(--accent); color: var(--accent); font-weight: 700; }

  /* ─── RESULTS SCREEN ─── */
  #results { display: none; position: relative; z-index: 1; min-height: 100vh; padding: 60px 24px; }
  .results-inner { max-width: 720px; margin: 0 auto; text-align: center; }
  .results-grade {
    font-family: 'Playfair Display', serif;
    font-size: clamp(3rem, 10vw, 6rem);
    font-weight: 900;
    line-height: 1;
    margin-bottom: 8px;
  }
  .results-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.6rem;
    margin-bottom: 8px;
  }
  .results-subtitle { color: var(--muted); margin-bottom: 48px; font-size: 0.95rem; }
  .results-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 40px;
  }
  .res-stat {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 20px;
  }
  .res-stat .val {
    font-family: 'DM Mono', monospace;
    font-size: 1.8rem;
    font-weight: 500;
    display: block;
    margin-bottom: 4px;
  }
  .res-stat .label { font-size: 0.75rem; color: var(--muted); text-transform: uppercase; letter-spacing: 1px; }
  .topic-breakdown {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 28px;
    margin-bottom: 32px;
    text-align: left;
  }
  .topic-breakdown h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1rem;
    margin-bottom: 20px;
    color: var(--muted);
  }
  .topic-row { margin-bottom: 16px; }
  .topic-row-header { display: flex; justify-content: space-between; margin-bottom: 6px; font-size: 0.82rem; }
  .topic-row-bar { background: var(--border); border-radius: 4px; height: 8px; overflow: hidden; }
  .topic-row-fill { height: 100%; border-radius: 4px; background: linear-gradient(90deg, var(--accent), var(--accent2)); transition: width 0.8s ease; }

  .results-buttons { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
  .btn-result {
    padding: 14px 28px;
    border-radius: 12px;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    font-family: 'DM Sans', sans-serif;
    border: none;
  }
  .btn-result.primary { background: var(--accent); color: #0d0f14; }
  .btn-result.primary:hover { background: #d9bc84; }
  .btn-result.secondary { background: var(--card); color: var(--text); border: 1px solid var(--border); }
  .btn-result.secondary:hover { border-color: var(--accent); color: var(--accent); }

  /* Timer */
  .timer-display {
    font-family: 'DM Mono', monospace;
    font-size: 0.9rem;
    color: var(--muted);
    padding: 6px 14px;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 8px;
  }
  .timer-display.warning { color: var(--accent3); border-color: var(--accent3); }

  /* Animations */
  @keyframes fadeDown { from { opacity: 0; transform: translateY(-16px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes fadeUp   { from { opacity: 0; transform: translateY(16px); }  to { opacity: 1; transform: translateY(0); } }
  @keyframes slideIn  { from { opacity: 0; transform: translateY(8px); }   to { opacity: 1; transform: translateY(0); } }
  @keyframes pop { 0%,100% { transform: scale(1); } 50% { transform: scale(1.08); } }
  .pop { animation: pop 0.3s ease; }

  /* Responsive */
  @media (max-width: 600px) {
    .mode-grid { grid-template-columns: 1fr; }
    .results-stats { grid-template-columns: 1fr 1fr; }
    .quiz-header { padding: 12px 16px; flex-wrap: wrap; }
    .question-area { padding: 0 16px; }
    .question-card { padding: 24px 20px; }
    .topic-nav { padding: 16px 16px 0; }
    .progress-bar-wrap { max-width: 160px; }
  }

  .hidden { display: none !important; }

  /* Sidebar grid in exam */
  .sidebar-toggle {
    position: fixed;
    bottom: 24px; right: 24px;
    background: var(--accent);
    color: #0d0f14;
    border: none;
    border-radius: 50%;
    width: 52px; height: 52px;
    font-size: 1.3rem;
    cursor: pointer;
    box-shadow: 0 4px 20px rgba(200,169,110,0.4);
    z-index: 200;
    transition: all 0.2s;
    display: none;
    align-items: center;
    justify-content: center;
  }
  .sidebar-toggle.visible { display: flex; }
  .sidebar-panel {
    position: fixed;
    bottom: 88px; right: 24px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 20px;
    width: 280px;
    z-index: 200;
    box-shadow: 0 8px 40px rgba(0,0,0,0.5);
    display: none;
  }
  .sidebar-panel.open { display: block; }
  .sidebar-panel h4 { font-size: 0.75rem; color: var(--muted); letter-spacing: 1px; text-transform: uppercase; margin-bottom: 12px; }

  .confetti-line { height: 4px; width: 100%; background: linear-gradient(90deg,#c8a96e,#4fc3a1,#e05c5c,#c8a96e); border-radius: 2px; margin-bottom: 32px; }
</style>
</head>
<body>

<!-- ════════════ INTRO ════════════ -->
<div id="intro">
  <div class="logo-badge">⚖️ &nbsp; Prawo Medyczne &nbsp; ⚕️</div>
  <h1 class="main-title">Interaktywny<br><span>Test Wiedzy</span></h1>
  <p class="subtitle">75 pytań z zakresu prawa medycznego podzielonych na 5 grup tematycznych. Wybierz tryb nauki lub egzaminu i sprawdź swoją wiedzę.</p>

  <div class="stats-row">
    <div class="stat-chip"><span class="num">5</span><span class="lbl">Grup tematycznych</span></div>
    <div class="stat-chip"><span class="num">75</span><span class="lbl">Pytań</span></div>
    <div class="stat-chip"><span class="num">3</span><span class="lbl">Poziomy trudności</span></div>
  </div>

  <div class="mode-grid">
    <div class="mode-card study" onclick="selectMode('study')">
      <span class="mode-icon">📖</span>
      <div class="mode-name">Samokształcenie</div>
      <div class="mode-desc">Natychmiastowy feedback po każdej odpowiedzi z uzasadnieniem prawnym. Ucz się we własnym tempie.</div>
    </div>
    <div class="mode-card exam" onclick="selectMode('exam')">
      <span class="mode-icon">🎓</span>
      <div class="mode-name">Egzamin</div>
      <div class="mode-desc">Symulacja egzaminu z limitem czasu 90 min. Wyniki i uzasadnienia dostępne po zakończeniu.</div>
    </div>
  </div>

  <div class="topic-select-area">
    <h3>Wybierz grupy tematyczne (min. 1):</h3>
    <div class="topic-pills" id="topicPills"></div>
    <button class="btn-start" id="startBtn" onclick="startQuiz()">
      Rozpocznij Test &rarr;
    </button>
  </div>
</div>

