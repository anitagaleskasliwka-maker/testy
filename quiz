        exp: "Terapia genowa linii zarodkowej (modyfikacje dziedziczne) jest zakazana w Konwencji z Oviedo (art. 13), przepisach większości państw UE i Polsce. Różni się od terapii somatycznej (dopuszczalnej) tym, że modyfikacja jest przekazywana potomstwu. Debata o CRISPR/Cas9 (cas He Jiankui) zaostrzył wymogi globalne.",
        law: "Art. 13 Konwencji z Oviedo; ustawa o GMO; KEL"
      },
      {
        q: "Zasada 'equipoise' (równowagi) w randomizowanych badaniach klinicznych oznacza, że:",
        opts: ["Obie grupy badania (kontrolna i eksperymentalna) muszą mieć równą liczbę uczestników","Randomizacja jest etycznie dopuszczalna tylko gdy istnieje stan szczerych wątpliwości w środowisku medycznym co do wyższości jednej metody nad drugą","Badanie musi trwać równo dla obu grup","Sponsor i badacz muszą podzielić koszty równo"],
        ans: 1, diff: "hard",
        exp: "Clinical equipoise (Freedman 1987) – fundamentalne kryterium etyczne RCT: randomizacja jest dopuszczalna tylko gdy społeczność naukowa nie jest przekonana co do wyższości żadnej z badanych opcji. Gdy equipoise zostaje zachwiana na korzyść jednej grupy, badanie powinno zostać przerwane. Wynika to z obowiązku działania w interesie uczestnika.",
        law: "Freedman B., NEJM 1987; ICH E10; Deklaracja Helsińska §33"
      }
    ]
  }
];

// ════════════════════════════════════════════════════════
//  STATE
// ════════════════════════════════════════════════════════
let state = {
  mode: 'study',
  selectedTopics: [0,1,2,3,4],
  questions: [],        // flattened array {topicId, topicName, ...q}
  answers: {},          // index -> {chosen, correct}
  currentQ: 0,
  currentTopic: 0,
  timerInterval: null,
  timeLeft: 90*60,
  reviewMode: false
};

// ════════════════════════════════════════════════════════
//  INIT
// ════════════════════════════════════════════════════════
function init() {
  // Build topic pills
  const pillsEl = document.getElementById('topicPills');
  pillsEl.innerHTML = '';
  TOPICS.forEach(t => {
    const p = document.createElement('div');
    p.className = 'topic-pill active';
    p.dataset.id = t.id;
    p.innerHTML = `${t.icon} ${t.name}`;
    p.onclick = () => toggleTopic(t.id, p);
    pillsEl.appendChild(p);
  });
}

function toggleTopic(id, el) {
  const idx = state.selectedTopics.indexOf(id);
  if (idx === -1) {
    state.selectedTopics.push(id);
    el.classList.add('active');
  } else {
    if (state.selectedTopics.length === 1) return; // at least 1
    state.selectedTopics.splice(idx, 1);
    el.classList.remove('active');
  }
}

function selectMode(m) {
  state.mode = m;
  document.querySelectorAll('.mode-card').forEach(c => c.style.borderColor = '');
  document.querySelector('.mode-card.' + m).style.borderColor = 'var(--accent)';
}

function startQuiz() {
  // Build questions list
  state.questions = [];
  TOPICS.filter(t => state.selectedTopics.includes(t.id)).forEach(t => {
    t.questions.forEach(q => {
      state.questions.push({ ...q, topicId: t.id, topicName: t.name, topicIcon: t.icon });
    });
  });
  state.answers = {};
  state.currentQ = 0;
  state.currentTopic = state.selectedTopics[0];
  state.reviewMode = false;

  document.getElementById('intro').style.display = 'none';
  document.getElementById('quiz').style.display = 'block';
  document.getElementById('results').style.display = 'none';

  // Mode badge
  const badge = document.getElementById('modeBadge');
  if (state.mode === 'study') {
    badge.textContent = '📖 Samokształcenie';
    badge.className = 'mode-badge study';
  } else {
    badge.textContent = '🎓 Egzamin';
    badge.className = 'mode-badge exam';
    // Start timer
    state.timeLeft = 90 * 60;
    document.getElementById('timerDisplay').classList.remove('hidden');
    updateTimer();
    state.timerInterval = setInterval(() => {
      state.timeLeft--;
      updateTimer();
      if (state.timeLeft <= 0) {
        clearInterval(state.timerInterval);
        showResults();
      }
    }, 1000);
    // Show sidebar toggle
    document.getElementById('sidebarToggle').classList.add('visible');
  }

  buildTopicNav();
  renderQuestion();
}

function buildTopicNav() {
  const nav = document.getElementById('topicNav');
  nav.innerHTML = '';
  const topicIds = [...new Set(state.questions.map(q => q.topicId))];
  topicIds.forEach(tid => {
    const t = TOPICS.find(x => x.id === tid);
    const btn = document.createElement('button');
    btn.className = 'topic-nav-btn' + (tid === state.currentTopic ? ' active' : '');
    btn.dataset.topicId = tid;
    btn.innerHTML = `<span class="dot"></span>${t.icon} ${t.name}`;
    btn.onclick = () => jumpToTopic(tid);
    nav.appendChild(btn);
  });
}

function jumpToTopic(tid) {
  const idx = state.questions.findIndex(q => q.topicId === tid);
  if (idx !== -1) { state.currentQ = idx; renderQuestion(); }
}

function renderQuestion() {
  const q = state.questions[state.currentQ];
  if (!q) return;
  state.currentTopic = q.topicId;

  // Update nav active
  document.querySelectorAll('.topic-nav-btn').forEach(b => {
    b.classList.toggle('active', parseInt(b.dataset.topicId) === q.topicId);
    // mark done
    const tId = parseInt(b.dataset.topicId);
    const tQs = state.questions.filter((x,i) => x.topicId === tId);
    const allAnswered = tQs.every((x,i) => {
      const globalIdx = state.questions.indexOf(x);
      return state.answers[globalIdx] !== undefined;
    });
    b.querySelector('.dot').style.background = allAnswered ? 'var(--accent2)' : '';
  });

  // Progress
  const total = state.questions.length;
  const answered = Object.keys(state.answers).length;
  document.getElementById('progressFill').style.width = (answered/total*100) + '%';
  document.getElementById('progressLabel').textContent = `${answered} / ${total}`;

  // Score
  const correct = Object.values(state.answers).filter(a => a.correct).length;
  document.getElementById('scoreDisplay').textContent = correct;

  // Q number
  document.getElementById('qNumber').textContent = `Pytanie ${state.currentQ+1}/${total}`;

  // Diff badge
  const diffEl = document.getElementById('diffBadge');
  const diffMap = { easy: ['Łatwe','diff-easy'], medium: ['Średnie','diff-medium'], hard: ['Trudne','diff-hard'] };
  diffEl.textContent = diffMap[q.diff][0];
  diffEl.className = 'diff-badge ' + diffMap[q.diff][1];

  // Question text
  document.getElementById('questionText').textContent = q.q;

  // Options
  const optsList = document.getElementById('optionsList');
  optsList.innerHTML = '';
  const letters = ['A','B','C','D'];
  q.opts.forEach((opt, i) => {
    const btn = document.createElement('button');
    btn.className = 'option-btn';
    btn.innerHTML = `<span class="opt-letter">${letters[i]}</span><span>${opt}</span>`;

    const ans = state.answers[state.currentQ];
    if (ans !== undefined) {
      btn.disabled = true;
      if (i === q.ans) {
        btn.classList.add(state.reviewMode ? 'reveal-correct' : 'correct');
      } else if (i === ans.chosen && !ans.correct) {
        btn.classList.add('wrong');
      } else if (state.mode === 'study' && i === q.ans) {
        btn.classList.add('reveal-correct');
      }
    } else {
      btn.onclick = () => selectAnswer(i);
    }
    optsList.appendChild(btn);
  });

  // Explanation
  const expBox = document.getElementById('explanationBox');
  const expText = document.getElementById('explanationText');
  const expLaw = document.getElementById('explanationLaw');
  const ans = state.answers[state.currentQ];
  if (ans !== undefined && (state.mode === 'study' || state.reviewMode)) {
    expText.textContent = q.exp;
    expLaw.textContent = '📋 Podstawa prawna: ' + q.law;
    expBox.classList.add('show');
  } else {
    expBox.classList.remove('show');
  }

  // Card answered
  document.getElementById('questionCard').classList.toggle('answered', ans !== undefined);

  // Prev/next buttons
  document.getElementById('prevBtn').disabled = state.currentQ === 0;
  const nextBtn = document.getElementById('nextBtn');
  if (state.currentQ === total-1) {
    nextBtn.textContent = state.mode === 'exam' && !state.reviewMode ? 'Zakończ Egzamin →' : 'Zakończ →';
    nextBtn.onclick = () => showResults();
  } else {
    nextBtn.textContent = 'Następne →';
    nextBtn.onclick = () => navigate(1);
  }

  // Mini grid
  updateMiniGrid();
  updateSidebarGrid();
}

function selectAnswer(chosen) {
  const q = state.questions[state.currentQ];
  const correct = chosen === q.ans;
  state.answers[state.currentQ] = { chosen, correct };
  renderQuestion();
  // pop animation
  document.getElementById('questionCard').classList.add('pop');
  setTimeout(() => document.getElementById('questionCard').classList.remove('pop'), 300);
}

function navigate(dir) {
  state.currentQ = Math.max(0, Math.min(state.questions.length-1, state.currentQ+dir));
  renderQuestion();
}

function updateMiniGrid() {
  const grid = document.getElementById('qGridMini');
  grid.innerHTML = '';
  // show current topic's questions
  const tQs = state.questions.map((q,i) => ({q,i})).filter(({q}) => q.topicId === state.currentTopic);
  tQs.forEach(({q,i}) => {
    const d = document.createElement('div');
    d.className = 'q-dot' + (i === state.currentQ ? ' current' : '');
    const a = state.answers[i];
    if (a) d.classList.add(a.correct ? 'answered-correct' : 'answered-wrong');
    d.textContent = i+1;
    d.onclick = () => { state.currentQ = i; renderQuestion(); };
    grid.appendChild(d);
  });
}

function updateSidebarGrid() {
  const grid = document.getElementById('sidebarGrid');
  if (!grid) return;
  grid.innerHTML = '';
  state.questions.forEach((q,i) => {
    const d = document.createElement('div');
    d.className = 'q-dot' + (i === state.currentQ ? ' current' : '');
    const a = state.answers[i];
    if (a) d.classList.add(a.correct ? 'answered-correct' : 'answered-wrong');
    d.textContent = i+1;
    d.title = q.topicName;
    d.onclick = () => { state.currentQ = i; renderQuestion(); toggleSidebar(); };
    grid.appendChild(d);
  });
}

function toggleSidebar() {
  document.getElementById('sidebarPanel').classList.toggle('open');
  updateSidebarGrid();
}

function updateTimer() {
  const m = Math.floor(state.timeLeft/60);
  const s = state.timeLeft%60;
  const el = document.getElementById('timerDisplay');
  el.textContent = `${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
  el.classList.toggle('warning', state.timeLeft < 300);
}

// ════════════════════════════════════════════════════════
//  RESULTS
// ════════════════════════════════════════════════════════
function showResults() {
  if (state.timerInterval) clearInterval(state.timerInterval);
  document.getElementById('quiz').style.display = 'none';
  document.getElementById('results').style.display = 'block';
  document.getElementById('sidebarToggle').classList.remove('visible');

  const total = state.questions.length;
  const correct = Object.values(state.answers).filter(a => a.correct).length;
  const wrong = Object.values(state.answers).filter(a => !a.correct).length;
  const skipped = total - Object.keys(state.answers).length;
  const pct = Math.round(correct/total*100);

  // Grade
  let grade, color;
  if (pct >= 90) { grade = 'A'; color = 'var(--accent2)'; }
  else if (pct >= 75) { grade = 'B'; color = 'var(--accent)'; }
  else if (pct >= 60) { grade = 'C'; color = '#a0b0ff'; }
  else { grade = 'F'; color = 'var(--accent3)'; }

  document.getElementById('resultsGrade').textContent = `${pct}%`;
  document.getElementById('resultsGrade').style.color = color;
  document.getElementById('resultsTitle').textContent = pct>=60 ? '🎉 Gratulacje!' : '📚 Warto powtórzyć';
  document.getElementById('resultsSubtitle').textContent = `Wynik: ${correct} z ${total} pytań poprawnie (${pct}%)`;
  document.getElementById('resCorrect').textContent = correct;
  document.getElementById('resWrong').textContent = wrong;
  document.getElementById('resSkipped').textContent = skipped;

  // Topic breakdown
  const bd = document.getElementById('topicBreakdown');
  bd.innerHTML = '<h3>Wyniki według grup tematycznych</h3>';
  const topicIds = [...new Set(state.questions.map(q => q.topicId))];
  topicIds.forEach(tid => {
    const t = TOPICS.find(x => x.id === tid);
    const tQs = state.questions.map((q,i) => ({q,i})).filter(({q}) => q.topicId === tid);
    const tCorrect = tQs.filter(({i}) => state.answers[i]?.correct).length;
    const tTotal = tQs.length;
    const tPct = tTotal > 0 ? Math.round(tCorrect/tTotal*100) : 0;
    bd.innerHTML += `
      <div class="topic-row">
        <div class="topic-row-header">
          <span>${t.icon} ${t.name}</span>
          <span style="font-family:'DM Mono',monospace;color:var(--accent)">${tCorrect}/${tTotal}</span>
        </div>
        <div class="topic-row-bar">
          <div class="topic-row-fill" style="width:${tPct}%"></div>
        </div>
      </div>`;
  });
}

function reviewAnswers() {
  state.reviewMode = true;
  state.currentQ = 0;
  document.getElementById('results').style.display = 'none';
  document.getElementById('quiz').style.display = 'block';
  // Change badge
  const badge = document.getElementById('modeBadge');
  badge.textContent = '🔍 Przegląd Odpowiedzi';
  badge.className = 'mode-badge study';
  renderQuestion();
}

function goHome() {
  if (state.timerInterval) clearInterval(state.timerInterval);
  document.getElementById('quiz').style.display = 'none';
  document.getElementById('results').style.display = 'none';
  document.getElementById('intro').style.display = 'flex';
  document.getElementById('timerDisplay').classList.add('hidden');
  document.getElementById('sidebarToggle').classList.remove('visible');
  document.getElementById('sidebarPanel').classList.remove('open');
  // Reset
  state = { mode: state.mode, selectedTopics: [0,1,2,3,4], questions: [], answers: {}, currentQ: 0, currentTopic: 0, timerInterval: null, timeLeft: 90*60, reviewMode: false };
}

// Boot
init();
selectMode('study');
</script>
</body>
</html>
